---
import * as fa from "@fortawesome/fontawesome-svg-core";

const classes = Astro.props.classes ?? [];
classes.push("icon");

const styles: fa.Styles = {};
if (Astro.props.color) {
  styles.color = Astro.props.color;
}

export interface Props {
  /** Name of the icon to use. */
  icon: fa.IconDefinition;
  /** Classes to apply to the icon. */
  classes?: string[];
  /** The colour of the icon. */
  color?: string;
}

const icon = fa.icon(Astro.props.icon, { classes, styles });
if (!icon?.html) {
  throw new Error(`Failed to retrieve icon HTML for ${Astro.props.icon}`);
}
---

<Fragment set:html={icon.html} />
