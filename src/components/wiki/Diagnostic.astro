---
import Icon from "../common/Icon.astro";
import Tooltip from "../common/Tooltip.astro";

import {
  faExclamation,
  faInfo,
  faLightbulb,
  faTriangleExclamation,
} from "@fortawesome/free-solid-svg-icons";

const LEVEL_ICONS = {
  Information: faInfo,
  Warning: faTriangleExclamation,
  Error: faExclamation,
  Hint: faLightbulb,
};

const { level } = Astro.props;

const icon = LEVEL_ICONS[level];

export interface Props {
  level: "Information" | "Warning" | "Error" | "Hint";
}
---

<div class:list={["diagnostic", level]}>
  <div>
    <slot name="name" />
    <Tooltip content={`Default severity: ${level}`}>
      <Icon icon={icon} />
    </Tooltip>
  </div>
  <slot />
</div>

<style lang="scss">
  div.diagnostic {
    border-radius: 0.5em;
    margin-top: 2em;

    & > div:first-of-type() {
      display: flex;
      justify-content: center;
      align-items: center;
      justify-content: space-between;

      :global(i.fa-solid) {
        color: var(--level-color);
        font-size: 2em;
      }

      :global(a > i.fa-solid) {
        color: white;
        font-size: 1em;
      }
    }

    &.Warning {
      --level-color: #ff9100;
    }

    &.Hint {
      --level-color: #aaaaaa;
    }

    &.Error {
      --level-color: #ff0000;
    }

    :global(.heading) {
      margin-top: 0px;
    }
  }
</style>
